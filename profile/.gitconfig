[include]
path = .gitconfig.local

[credential "https://github.com"]
	helper =
	helper = !/run/current-system/sw/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/run/current-system/sw/bin/gh auth git-credential

[filter "lfs"]
required = true
clean = git-lfs clean -- %f
smudge = git-lfs smudge -- %f
process = git-lfs filter-process

[apply]
# Detect whitespace errors when applying a patch
whitespace = fix

[core]
editor = nano
# Treat spaces before tabs and all kinds of trailing whitespace as an error
# [default] trailing-space: looks for spaces at the end of a line
# [default] space-before-tab: looks for spaces before tabs at the beginning of a line
whitespace = space-before-tab,-indent-with-non-tab,trailing-space
# Make `git rebase` safer on macOS
# More info: <http://www.git-tower.com/blog/make-git-rebase-safe-on-osx/>
trustctime = false
# Prevent showing files whose names contain non-ASCII symbols as unversioned.
# http://michael-kuehnel.de/git/2014/11/21/git-mac-osx-and-german-umlaute.html
precomposeunicode = false
# Speed up commands involving untracked files such as `git status`.
# https://git-scm.com/docs/git-update-index#_untracked_cache
untrackedCache = true

[color]
ui = auto

[diff]
tool = code
# Detect copies as well as renames
renames = copies

[help]
# Automatically correct and execute mistyped commands
autocorrect = 1

[init]
defaultBranch = main

[merge]
tool = code
# Include summaries of merged commits in newly created merge commit messages
log = true

[pager]
branch = false
log = false

[pull]
rebase = true

[push]
# Make `git push` push relevant annotated tags when pushing branches out.
followTags = true

[pretty]
commit = tformat:%C(red)%h %C(green)(%ci) %C(bold blue)<%an> %C(reset)%s%C(yellow)%d%C(reset)
commit-date = format:%ci
commit-timestamp = format:%ct
commit-one = format:%C(red)%h %C(green)(%ci) %C(bold blue)<%an> %C(reset)%s%C(yellow)%d%C(reset)

[alias]
a = "add"
aa = "add ."
ahead = "rev-list --count HEAD ^@{u}"
behind = "rev-list --count @{u} ^HEAD"
behind-ahead = "!git upstream >/dev/null && git rev-list --count --left-right '@{u}...HEAD' | awk '{print ($1?\"↓\"$1:\"\") ($2?\"↑\"$2:\"\")}'"
br = "branch"
c = "commit"
ca = "commit -a"
cam = "commit -am"
cb = "branch --show-current"
cbf = "branch --points-at HEAD --color=always --format='%(color:blue bold) %(refname:short)'"
changes = "!printf '%s' \"$(git unmergedcf) $(git unstagedcf) $(git stagedcf) $(git untrackedcf)\" | tr -s ' '"
cl = "clean -fd"
cm = "commit -m"
co = "checkout"
cob = "checkout -b"
cp = "cherry-pick"
d = "diff"
del = "branch -D"
delb = "!git checkout \"$(git main)\"; git branch -D '@{-1}'"
fp = "push --force-with-lease"
is-clean = "![ -z \"$(git sp)\" ] && printf '✅'"
l = "log --pretty=commit"
last = "log -1 --pretty=commit-one"
last-date = "log -1 --pretty=commit-date"
last-timestamp = "log -1 --pretty=commit-timestamp"
lg = "l --graph"
lt = "!git tag --sort=-v:refname | head -n 1"
main = "!git remote show origin | grep 'HEAD branch' | sed 's/.*: //'"
p = "push"
past = "!f() { [ $(uname -s) = 'Darwin' ] && F=v || F=d; D=$(date -$F \"$(git last-date) + $1 $((RANDOM % 10 + 1)) minutes $((RANDOM % 60 + 1)) seconds\" '+%Y-%m-%d %H:%M:%S %z'); shift; GIT_AUTHOR_DATE=\"$D\" GIT_COMMITTER_DATE=\"$D\" git \"$@\"; }; f"
pb = "!git push --set-upstream origin \"$(git cb)\""
pl = "pull"
prev = "checkout @{-1}"
r = "reset --hard"
s = "status"
sp = "status --porcelain --untracked-files=all"
ss = "!git rev-parse --git-dir >/dev/null && printf '%s' \"$(git cbf) $(git behind-ahead) $(git is-clean || git changes) $(git stashcf)\""
st = "stash"
staged = "diff --cached --name-only"
stagedc = "!git staged | wc -l"
stagedcf = "!git stagedc | awk '{print ($1>0)?\"➕ \"$1:\"\"}'"
stashc = "!git stl | wc -l"
stashcf = "!git stashc | awk '{print ($1>0)?\"📥 \"$1:\"\"}'"
stl = "st list"
t = "tag"
undo = "reset HEAD~1 --mixed"
unmerged = "ls-files --unmerged"
unmergedc = "!git unmerged | cut -f4 | sort -u | wc -l"
unmergedcf = "!git unmergedc | awk '{print ($1>0)?\"❌ \"$1:\"\"}'"
unstaged = "diff --name-only"
unstagedc = "!git unstaged | wc -l"
unstagedcf = "!git unstagedc | awk '{print ($1>0)?\"⭕ \"$1:\"\"}'"
untracked = "ls-files --others --exclude-standard"
untrackedc = "!git untracked | wc -l"
untrackedcf = "!git untrackedc | awk '{print ($1>0)?\"... \"$1:\"\"}'"
up = "!m=$(git main); git checkout \"$m\" git pull; git prev; git rebase \"$m\""
upstream = "rev-parse --verify -q --abbrev-ref @{u}"
