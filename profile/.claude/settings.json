{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 7,
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(npm run:*)",
      "Bash(pnpm run:*)",
      "Bash(yarn run:*)"
    ],
    "deny": [
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(curl:*)",
      "Bash(git push:*)",
      "Bash(ssh:*)",
      "Bash(su:*)",
      "Bash(sudo:*)",
      "Bash(wget:*)",
      "Read(**/.env.*)",
      "Read(**/.env)",
      "Read(**/.secrets)",
      "Read(**/secrets.*)"
    ],
    "ask": [
      "Bash(bundle:*)",
      "Bash(gem:*)",
      "Bash(mv:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pnpm:*)",
      "Bash(poetry:*)",
      "Bash(rm:*)",
      "Bash(uv:*)",
      "Bash(yarn:*)",
      "WebFetch",
      "WebSearch"
    ],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "disableAutoMode": "disable"
  },
  "enableAllProjectMcpServers": false,
  "enabledPlugins": {
    "astro@community": true,
    "aws-agents@claude-plugins-official": true,
    "aws-core@claude-plugins-official": true,
    "aws-data-analytics@claude-plugins-official": true,
    "aws@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "cloudflare@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "datadog@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": true,
    "feature-dev@claude-plugins-official": true,
    "firebase@claude-plugins-official": true,
    "firebase@firebase": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "liquid-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pydantic-ai@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "firebase": {
      "source": {
        "source": "github",
        "repo": "firebase/firebase-tools"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyWrite": [
        "./.claude/settings.json",
        "/etc/claude-code/managed-settings.json",
        "~/.claude/settings.json"
      ],
      "denyRead": [
        "~/.aws",
        "~/.azure",
        "~/.bash_history",
        "~/.bash_profile",
        "~/.bashrc",
        "~/.cargo/credentials",
        "~/.config",
        "~/.kube/config",
        "~/.gnupg",
        "~/.local",
        "~/.mozilla",
        "~/.npmrc",
        "~/.pnpm-store",
        "~/.profile",
        "~/.ssh",
        "~/.yarnrc.yml",
        "~/.yarnrc",
        "~/.zsh_history",
        "~/.zshrc"
      ]
    }
  },
  "autoUpdatesChannel": "stable"
}
